rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dữ liệu xe: khách (chưa đăng nhập) ĐỌC được; chỉ admin đã đăng nhập mới GHI.
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Mặc định khóa toàn bộ phần còn lại.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
